{
  "routes": [
    { "src": "^/privacy-policy$",       "dest": "/privacy-policy.html" },
    { "src": "^/terms-and-conditions$", "dest": "/terms-and-conditions.html" },
    { "src": "^/terms$",                "status": 301, "headers": { "Location": "/terms-and-conditions" } },
    { "src": "^/$",                     "dest": "/landing.html" },
    { "handle": "filesystem" },
    { "src": "^/(.*)$",                 "dest": "/index.html" }
  ]
}
